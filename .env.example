# ── Auth (Required) ──────────────────────────────────────────
AUTH_SECRET=your-random-secret-minimum-32-chars
AUTH_URL=https://needcitrus.com/5mouse

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: https://needcitrus.com/5mouse/api/auth/callback/github
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# Google OAuth (optional)
# Callback URL: https://needcitrus.com/5mouse/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── API Keys ─────────────────────────────────────────────────
# Anthropic API key for Claude CLI (or users set their own in Settings)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub PAT for pushing repos
GITHUB_TOKEN=ghp_...

# Encryption key for stored user API keys (defaults to AUTH_SECRET)
ENCRYPTION_KEY=

# ── Infrastructure ───────────────────────────────────────────
# Override data directory (default: ./data)
# DATA_DIR=/data

# Server port (default: 4000)
# PORT=4000

# Database (set by docker-compose, override for external DB)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/platform?schema=public
