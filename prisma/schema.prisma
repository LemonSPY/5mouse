generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Auth (NextAuth) ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  teamMemberships TeamMember[]
  projectMemberships ProjectMember[]
  createdProjects Project[]  @relation("CreatedBy")
  createdTemplates Template[] @relation("TemplateCreator")
  messages       Message[]

  @@map("users")
}

enum UserRole {
  ADMIN
  MEMBER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Teams ────────────────────────────────────────────────────────

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  TeamMember[]
  projects Project[]

  @@map("teams")
}

model TeamMember {
  id     String   @id @default(cuid())
  teamId String
  userId String
  role   TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ── Projects ─────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String
  status      ProjectStatus @default(IDLE)
  idea        String        @db.Text
  plan        Json?
  teamId      String?
  templateId  String?
  gitRepoUrl  String?
  gitBranch   String?       @default("main")
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy  User            @relation("CreatedBy", fields: [createdById], references: [id])
  team       Team?           @relation(fields: [teamId], references: [id])
  template   Template?       @relation(fields: [templateId], references: [id])
  members    ProjectMember[]
  agents     Agent[]
  tasks      Task[]
  messages   Message[]
  debugSessions DebugSession[]

  @@index([createdById])
  @@index([teamId])
  @@index([status])
  @@map("projects")
}

enum ProjectStatus {
  IDLE
  PLANNING
  PLAN_REVIEW
  BUILDING
  REVIEW
  MODIFYING
  DEBUGGING
  DONE
  ERROR
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(COLLABORATOR)
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

enum ProjectRole {
  OWNER
  COLLABORATOR
  VIEWER
}

// ── Agents ───────────────────────────────────────────────────────

model Agent {
  id           String      @id @default(cuid())
  type         AgentType
  status       AgentStatus @default(IDLE)
  projectId    String
  currentTaskId String?
  startedAt    DateTime    @default(now())
  completedAt  DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks    Task[]    @relation("AssignedAgent")
  messages Message[]

  @@index([projectId])
  @@index([status])
  @@map("agents")
}

enum AgentType {
  PLANNER
  ARCHITECT
  CODER
  TESTER
  DEBUGGER
  REVIEWER
  DEVOPS
}

enum AgentStatus {
  IDLE
  RUNNING
  PAUSED
  COMPLETED
  ERROR
  CANCELLED
}

// ── Tasks ────────────────────────────────────────────────────────

model Task {
  id              String     @id @default(cuid())
  projectId       String
  title           String
  description     String?    @db.Text
  status          TaskStatus @default(PENDING)
  assignedAgentId String?
  priority        Int        @default(0)
  dependsOn       String[]   @default([])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  completedAt     DateTime?

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedAgent Agent?  @relation("AssignedAgent", fields: [assignedAgentId], references: [id])

  @@index([projectId])
  @@index([status])
  @@map("tasks")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

// ── Messages ─────────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  projectId String
  agentId   String?
  userId    String?
  role      String   // user | assistant | system
  type      String   @default("text") // text | plan | tool_call | tool_result | error | status
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent   Agent?  @relation(fields: [agentId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([projectId, createdAt])
  @@index([agentId])
  @@map("messages")
}

// ── Templates ────────────────────────────────────────────────────

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  category    String
  blueprint   Json
  createdById String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?     @relation("TemplateCreator", fields: [createdById], references: [id])
  projects  Project[]

  @@index([category])
  @@map("templates")
}

// ── Debug Sessions ───────────────────────────────────────────────

model DebugSession {
  id           String            @id @default(cuid())
  projectId    String
  errorType    String
  errorMessage String            @db.Text
  stackTrace   String?           @db.Text
  status       DebugSessionStatus @default(OPEN)
  fixApplied   String?           @db.Text
  createdAt    DateTime          @default(now())
  resolvedAt   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("debug_sessions")
}

enum DebugSessionStatus {
  OPEN
  INVESTIGATING
  FIX_PROPOSED
  FIX_APPLIED
  RESOLVED
  WONT_FIX
}
